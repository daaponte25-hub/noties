@using NotiesBlazor.Controllers
@using NotiesBlazor.Models
@using static NotiesBlazor.Controllers.MateriasController
@inject MateriasController MateriasCtrl
@inject UserController UserCtrl
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Class" Class="mr-3"/> Registrar Materia
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string" Label="Nombre de la Materia" @bind-Value="materia.Nombre" Required="true" Class="mb-3" />
        
        <MudSelect T="string" Label="Docente Asignado" @bind-Value="materia.Profesor" Required="true" AnchorOrigin="Origin.BottomCenter">
            @if (listaDocentes == null)
            {
                <MudSelectItem Value="@(string.Empty)" Disabled="true">Cargando planta docente...</MudSelectItem>
            }
            else if (!listaDocentes.Any())
            {
                <MudSelectItem Value="@(string.Empty)" Disabled="true">No hay docentes activos registrados</MudSelectItem>
            }
            else
            {
                @foreach (var docente in listaDocentes)
                {
                    <MudSelectItem Value="@docente.FullName">@docente.FullName</MudSelectItem>
                }
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Guardar" Disabled="@string.IsNullOrEmpty(materia.Profesor)">Guardar Materia</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;

    private Materia materia = new();
    private List<User>? listaDocentes;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var todosLosUsuarios = await UserCtrl.GetUsersAsync(); 
            
            listaDocentes = todosLosUsuarios
                .Where(u => u.Role == UserRole.Docente && u.Status == UserStatus.Activo)
                .OrderBy(u => u.FullName)
                .ToList();
        }
        catch
        {
            Snackbar.Add("Atención: No se pudo verificar la lista de docentes.", Severity.Warning);
            listaDocentes = new();
        }
    }

    private void Cancelar() => MudDialog.Cancel();

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(materia.Nombre))
        {
            Snackbar.Add("El nombre de la materia no puede estar vacío.", Severity.Error);
            return;
        }

        try
        {
            await MateriasCtrl.CreateMateriaAsync(materia);
            
            Snackbar.Add("Materia registrada exitosamente.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}