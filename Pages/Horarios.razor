@page "/horarios"
@using NotiesBlazor.Controllers

@if (currentUser == null)
{
    <div style="flex-grow: 1; display: flex; align-items: center; justify-content: center; font-weight: bold; height: 100vh;">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </div>
}
else
{
    <header style="height: 80px; background-color: white; border-bottom: 1px solid #e2e8f0; padding: 0 2.5rem; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;">
        <div style="text-align: left;">
            <h2 style="font-size: 1.5rem; font-weight: 800; color: #0f172a; margin: 0; letter-spacing: -0.025em; text-align: left;">Horarios Escolares</h2>
            <p style="font-size: 11px; color: #64748b; font-weight: 600; font-style: italic; margin: 0; text-align: left;">Noties • Panel Cronológico</p>
        </div>
        <div style="display: flex; align-items: center; gap: 0.5rem; background-color: #e0e7ff; color: #3730a3; padding: 0.375rem 0.75rem; border-radius: 0.5rem; font-size: 0.75rem; font-weight: bold; border: 1px solid #c7d2fe;">
            <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" />
            Horarios Escolares
        </div>
    </header>

    <div style="flex-grow: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem; background-color: #f8fafc; text-align: center;">
        <div style="max-width: 480px; background-color: white; padding: 3rem 2rem; border-radius: 1rem; border: 1px solid #e2e8f0; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05); display: flex; flex-direction: column; align-items: center;">
            <div style="width: 72px; height: 72px; background-color: #fef3c7; border: 2px solid #fcd34d; border-radius: 1.5rem; display: flex; align-items: center; justify-content: center; color: #d97706; margin-bottom: 1.5rem;">
                <MudIcon Icon="@Icons.Material.Filled.Construction" Style="font-size: 2.5rem;" />
            </div>
            
            <h2 style="font-size: 1.5rem; font-weight: 900; color: #0f172a; margin-bottom: 0.5rem; letter-spacing: -0.025em;">Opción en Construcción</h2>
            <span style="font-size: 10px; font-weight: bold; text-transform: uppercase; color: #94a3b8; letter-spacing: 0.1em; margin-bottom: 1.5rem;">
                Horarios Escolares
            </span>

            <p style="font-size: 0.875rem; color: #475569; line-height: 1.6; margin-bottom: 1.5rem;">
                ¡Hola, <span style="font-weight: bold; color: #1e293b;">@currentUser.FullName</span>! Te informamos que el módulo de <strong>Horarios Escolares</strong> se encuentra actualmente en fase activa de diseño y desarrollo tecnológico para los siguientes módulos del sistema académico de Noties.
            </p>

            <div style="width: 100%; height: 6px; background-color: #f1f5f9; border-radius: 9999px; overflow: hidden; margin-bottom: 1.5rem;">
                <div style="width: 60%; height: 100%; background-color: #f59e0b; border-radius: 9999px;"></div>
            </div>

            <span style="font-size: 11px; color: #94a3b8; font-weight: 500; font-style: italic;">Pronto tendrás acceso a estas herramientas de gestión institucional.</span>
        </div>
    </div>
}

@code {
    [Inject] private UserController UserController { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private User? currentUser;

    protected override void OnInitialized()
    {
        currentUser = UserController.SessionUser;
        if (currentUser == null)
        {
            Navigation.NavigateTo("/login");
        }
    }
}
