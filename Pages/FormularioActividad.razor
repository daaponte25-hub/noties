@using noties.Models
@using NotiesBlazor.Controllers
@inject ActividadController ActividadCtrl
@inject UserController UserCtrl
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="mr-3"/> Crear Evaluación
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string" Label="Nombre de la Actividad" @bind-Value="actividad.Nombre" Required="true" Class="mb-3" />
        <MudTextField T="string" Label="Descripción (Temas, pautas...)" @bind-Value="actividad.Descripcion" Lines="2" Class="mb-3" />
        <MudNumericField T="double" Label="Porcentaje de Evaluación (1-100)" @bind-Value="actividad.Porcentaje" Min="1" Max="100" Required="true" Suffix="%" Class="mb-3" />
        <MudNumericField T="double?" Label="Nota Inicial Opcional (0-20)" @bind-Value="actividad.Nota" Min="0" Max="20" HelperText="Dejar vacío si aún no se ha entregado" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Guardar">Registrar Actividad</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;
    
    [Parameter] public int MateriaId { get; set; }

    private Actividad actividad = new();

    protected override void OnInitialized()
    {
        actividad.MateriaId = MateriaId;
    }

    private void Cancelar() => MudDialog.Cancel();

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(actividad.Nombre))
        {
            Snackbar.Add("El nombre de la actividad es obligatorio.", Severity.Warning);
            return;
        }

        try
        {
            actividad.CreadoPor = UserCtrl.SessionUser?.FullName ?? "Sistema";

            await ActividadCtrl.CreateActividadAsync(actividad);
            Snackbar.Add("Actividad creada con éxito.", Severity.Success);
            
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}